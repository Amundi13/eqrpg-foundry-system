<section class="tab {{tab.cssClass}}" data-group="sheet" data-tab="actions" id="{{partId}}">

  <div class="inventory-section">
    <div class="section-header">
      <h3>{{localize "EQRPG.QuickActions"}}</h3>
    </div>
    <div class="npc-quick-actions">
      <section class="npc-quick-action-block">
        <div class="npc-quick-action-header">{{localize "EQRPG.QuickAttacks"}}</div>
        {{#if statblockAttacks.length}}
        <div class="npc-quick-action-list">
          {{#each statblockAttacks as |attack|}}
          <div class="npc-quick-action-row">
            <div class="npc-quick-action-copy">
              <span class="npc-quick-action-name">{{attack.label}}</span>
              <span class="npc-quick-action-detail">{{attack.attackText}}</span>
              {{#if attack.damageText}}
              <span class="npc-quick-action-detail dim">{{attack.damageText}}</span>
              {{/if}}
            </div>
            <div class="npc-quick-action-controls">
              <button type="button" class="roll-btn atk-btn"
                      data-action="rollStatblockAttack" data-attack-id="{{attack.id}}">ATK</button>
              {{#if attack.damageFormula}}
              <button type="button" class="roll-btn dmg-btn"
                      data-action="rollStatblockDamage" data-attack-id="{{attack.id}}">DMG</button>
              {{/if}}
            </div>
          </div>
          {{/each}}
        </div>
        {{else}}
        <p class="empty-list">{{localize "EQRPG.NoStatblockAttacks"}}</p>
        {{/if}}
      </section>

      <section class="npc-quick-action-block">
        <div class="npc-quick-action-header">{{localize "EQRPG.SpecialAbilities"}}</div>
        {{#if specialAbilities.length}}
        <div class="npc-quick-action-list">
          {{#each specialAbilities as |ability|}}
          <div class="npc-quick-action-row">
            <div class="npc-quick-action-copy">
              <span class="npc-quick-action-name">{{ability.label}}</span>
              {{#if ability.description}}
              <span class="npc-quick-action-detail">{{ability.description}}</span>
              {{/if}}
            </div>
            <div class="npc-quick-action-controls">
              <button type="button" class="roll-btn cast-btn"
                      data-action="useSpecialAbility" data-ability-id="{{ability.id}}">
                {{localize "EQRPG.Use"}}
              </button>
            </div>
          </div>
          {{/each}}
        </div>
        {{else}}
        <p class="empty-list">{{localize "EQRPG.NoSpecialAbilities"}}</p>
        {{/if}}
      </section>
    </div>
  </div>

  {{!-- Weapons --}}
  <div class="inventory-section">
    <div class="section-header">
      <h3>{{localize "EQRPG.Weapons"}}</h3>
      {{#if isEditable}}
      <button type="button" data-action="createItem" data-type="weapon" class="create-btn"
              title="{{localize 'EQRPG.AddWeapon'}}">+</button>
      {{/if}}
    </div>
    {{#if weapons.length}}
    <ul class="item-list">
      {{#each weapons as |item|}}
      <li class="item" data-item-id="{{item.id}}">
        <img src="{{item.img}}" class="item-img" width="24" height="24" />
        <span class="item-name" data-action="editItem">{{item.name}}</span>
        <span class="item-detail">{{item.system.damage}} {{item.system.damageType}}</span>
        <span class="item-detail dim" title="{{localize 'EQRPG.WeaponDelay'}}">DLY {{item.system.delay}}</span>
        <span class="item-detail dim" title="{{localize 'EQRPG.CritRange'}} / {{localize 'EQRPG.CritMult'}}">
          {{#if (lt item.system.critRange 20)}}{{item.system.critRange}}–20{{else}}20{{/if}}×{{item.system.critMult}}
        </span>
        <div class="item-controls">
          <button type="button" data-action="rollAttack" class="roll-btn atk-btn"
                  title="{{localize 'EQRPG.RollAttack'}}">ATK</button>
          <button type="button" data-action="rollDamage" class="roll-btn dmg-btn"
                  title="{{localize 'EQRPG.RollDamage'}}">DMG</button>
          {{#if @root.isEditable}}
          <button type="button" data-action="deleteItem" class="delete-btn">✕</button>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="empty-list">{{localize "EQRPG.NoWeapons"}}</p>
    {{/if}}
  </div>

  {{!-- Spells --}}
  <div class="inventory-section">
    <div class="section-header">
      <h3>{{localize "EQRPG.Spells"}}</h3>
      {{#if isEditable}}
      <button type="button" data-action="createItem" data-type="spell" class="create-btn"
              title="{{localize 'EQRPG.AddSpell'}}">+</button>
      {{/if}}
    </div>
    {{#if spells.length}}
    <ul class="item-list">
      {{#each spells as |item|}}
      <li class="item" data-item-id="{{item.id}}">
        <img src="{{item.img}}" class="item-img" width="24" height="24" />
        <span class="item-name" data-action="editItem">{{item.name}}</span>
        <span class="item-detail">Lvl {{item.system.spellLevel}}</span>
        {{#if item.system.manaCost}}
        <span class="item-detail dim">{{item.system.manaCost}} MP</span>
        {{/if}}
        {{#if item.system.range}}
        <span class="item-detail dim">{{item.system.range}}</span>
        {{/if}}
        <div class="item-controls">
          <button type="button" data-action="castSpell" class="roll-btn cast-btn"
                  title="{{localize 'EQRPG.Cast'}}">✦ {{localize "EQRPG.Cast"}}</button>
          {{#if @root.isEditable}}
          <button type="button" data-action="deleteItem" class="delete-btn">✕</button>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="empty-list">—</p>
    {{/if}}
  </div>

  {{!-- Special Abilities / Skills --}}
  <div class="inventory-section">
    <div class="section-header">
      <h3>{{localize "EQRPG.Skills"}}</h3>
      {{#if isEditable}}
      <button type="button" data-action="createItem" data-type="skill" class="create-btn"
              title="{{localize 'EQRPG.AddSkill'}}">+</button>
      {{/if}}
    </div>
    {{#if skills.length}}
    <ul class="item-list">
      {{#each skills as |item|}}
      <li class="item" data-item-id="{{item.id}}">
        <img src="{{item.img}}" class="item-img" width="24" height="24" />
        <span class="item-name" data-action="editItem">{{item.name}}</span>
        <span class="item-detail">{{item.system.ranks}} ranks</span>
        {{#if item.system.ability}}
        <span class="item-detail dim">{{item.system.ability}}</span>
        {{/if}}
        <div class="item-controls">
          <button type="button" data-action="rollSkill" class="roll-btn skill-roll-btn"
                  title="{{localize 'EQRPG.RollSkill'}}">ROLL</button>
          {{#if @root.isEditable}}
          <button type="button" data-action="deleteItem" class="delete-btn">✕</button>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="empty-list">{{localize "EQRPG.NoSkills"}}</p>
    {{/if}}
  </div>

</section>
